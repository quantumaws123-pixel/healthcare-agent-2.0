# Database Configuration
# For Supabase: DATABASE_HOST=db.[ref].supabase.co, DATABASE_NAME=postgres
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=healthcare_agent
DATABASE_USER=postgres
DATABASE_PASSWORD=your_password_here
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# API Server Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true

# CORS Configuration (comma-separated list)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ML Model Configuration
MODEL_VERSION=latest
MODEL_PATH=./models
MODEL_TYPE=XGBoost

# Logging Configuration
LOG_LEVEL=INFO
LOG_FORMAT=json

# Cache Configuration
CACHE_TTL_SECONDS=300
CACHE_ENABLED=true

# Pagination Configuration
DEFAULT_PAGE_SIZE=10
MAX_PAGE_SIZE=100

# Rate Limiting (requests per hour per client)
RATE_LIMIT=1000

# SHAP Configuration
SHAP_BACKGROUND_SAMPLES=100
SHAP_TIMEOUT_SECONDS=1

# Prediction Performance
PREDICTION_TIMEOUT_MS=500

# Feature Engineering
FEATURE_WINDOW_DAYS=30
TREND_ANALYSIS_DAYS=7

# Data Processing
IMPUTATION_STRATEGY=median
NORMALIZATION_METHOD=minmax
TRAIN_TEST_SPLIT=0.7,0.15,0.15
