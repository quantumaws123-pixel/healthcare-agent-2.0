# ══════════════════════════════════════════════════════
# Healthcare Agent 2.0 — Environment Variables
# Copy this file to .env and fill in the values.
# Never commit .env to version control.
# ══════════════════════════════════════════════════════

# ── Database (Supabase Postgres) ──────────────────────
# For Supabase Session Pooler use:
#   DATABASE_HOST=aws-1-<region>.pooler.supabase.com
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=postgres
DATABASE_USER=postgres
DATABASE_PASSWORD=your_database_password_here
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=5

# ── API Server ────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true

# ── CORS (comma-separated) ────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,https://your-frontend.vercel.app

# ── JWT Security ──────────────────────────────────────
# REQUIRED: Use a long random string (minimum 32 characters)
JWT_SECRET_KEY=CHANGE_ME_use_a_long_random_string_at_least_32_chars
JWT_ALGORITHM=HS256
JWT_ACCESS_EXPIRE_MINUTES=60
JWT_REFRESH_EXPIRE_DAYS=30

# ── Google OAuth ──────────────────────────────────────
# Get from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ── Deployment URLs ───────────────────────────────────
# Must match your actual deployment URLs exactly
FRONTEND_URL=https://your-app.vercel.app
BACKEND_URL=https://your-api.onrender.com

# ── ML Model ──────────────────────────────────────────
MODEL_VERSION=latest
MODEL_PATH=./models
MODEL_TYPE=XGBoost

# ── Logging ───────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=json

# ── Cache ─────────────────────────────────────────────
CACHE_TTL_SECONDS=300
CACHE_ENABLED=true

# ── Feature Engineering ───────────────────────────────
FEATURE_WINDOW_DAYS=30
TREND_ANALYSIS_DAYS=7

# ── Prediction ────────────────────────────────────────
PREDICTION_TIMEOUT_MS=500
SHAP_BACKGROUND_SAMPLES=100
SHAP_TIMEOUT_SECONDS=1

# ── Pagination ────────────────────────────────────────
DEFAULT_PAGE_SIZE=10
MAX_PAGE_SIZE=100
RATE_LIMIT=1000
